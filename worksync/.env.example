# ══════════════════════════════════════════════════════════════════
#  WorkSync — Environment Variables
#  Copy this file to .env and fill in every value marked ← REQUIRED
# ══════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas  ← REQUIRED ──────────────────────────────────────
#
#  How to get this string:
#  1. Go to https://cloud.mongodb.com
#  2. Click your Cluster  →  Connect  →  Drivers
#  3. Select: Driver = Node.js, Version = 5.5 or later
#  4. Copy the connection string — it looks like:
#     mongodb+srv://nanthini:<db_password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
#  5. Replace <db_password> with your actual Atlas password
#  6. Add /worksync before the ? to target a specific database:
#     mongodb+srv://nanthini:mypassword@cluster0.xxxxx.mongodb.net/worksync?retryWrites=true&w=majority
#
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/worksync?retryWrites=true&w=majority&appName=Cluster0

# ── JWT  ← REQUIRED ────────────────────────────────────────────────
#  Use any long random string — at least 32 characters
#  Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d

# ── File Uploads ────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ── CORS ────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── GitHub Integration (optional) ──────────────────────────────────
#  Increases GitHub API rate limit from 60 → 5000 requests/hour
#  Get token: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=

# ── AI Features (optional) ─────────────────────────────────────────
AI_API_KEY=
